# ===========================================
# INDODAX TRADING BOT - ENVIRONMENT VARIABLES
# ===========================================

# -------------------------------------------
# INDODAX API KEYS (Required)
# -------------------------------------------
# Get API Key from: https://indodax.com/member/api
# Encrypt using: python utils/encrypt_keys.py
# Plain text keys (not recommended):
#   INDODAX_API_KEY=your_api_key_here
#   INDODAX_SECRET_KEY=your_secret_key_here

# Encrypted API keys (recommended):
INDODAX_API_KEY_ENC=""
INDODAX_SECRET_KEY_ENC=""

# -------------------------------------------
# TELEGRAM NOTIFICATIONS (Optional)
# -------------------------------------------
# Create bot at @BotFather, get chat ID by sending /start
TELEGRAM_BOT_TOKEN_ENC=""
TELEGRAM_CHAT_ID=""

# -------------------------------------------
# ENCRYPTION KEY (Keep secret!)
# -------------------------------------------
# Required to decrypt API keys. Generate via python utils/encrypt_keys.py
# ENCRYPTION_KEY=""

# -------------------------------------------
# TRADING SETTINGS (Optional — overrides config.json)
# -------------------------------------------
TRADING_PAIR="BTC_IDR"
STRATEGY="TA"
TIMEFRAME="1h"
INITIAL_BALANCE=10000000
MAX_RISK_PER_TRADE=0.02
MAX_DRAWDOWN=0.05

# -------------------------------------------
# LOGGING SETTINGS
# -------------------------------------------
LOG_LEVEL="INFO"
LOG_FILE="logs/bot.log"
