# ===========================================
# INDODAX TRADING BOT - ENVIRONMENT VARIABLES
# ===========================================

# -------------------------------------------
# INDODAX API KEYS (Wajib diisi)
# -------------------------------------------
# Dapatkan API Key dari: https://indodax.com/member/api
# Enkripsi menggunakan: python utils/encrypt_keys.py
# Jika tidak di-encrypt, isi langsung (tidak direkomendasikan)

# API Key (plain text - tidak aman)
# INDODAX_API_KEY=your_api_key_here
# INDODAX_SECRET_KEY=your_secret_key_here

# API Key (encrypted - direkomendasikan)
INDODAX_API_KEY_ENC=""
INDODAX_SECRET_KEY_ENC=""

# -------------------------------------------
# TELEGRAM NOTIFICATIONS (Opsional)
# -------------------------------------------
# Buat bot di @BotFather untuk mendapatkan token
# Dapatkan chat ID dengan mengirim /start ke bot

# Bot Token (plain text)
# TELEGRAM_BOT_TOKEN=your_bot_token

# Bot Token (encrypted)
TELEGRAM_BOT_TOKEN_ENC=""
TELEGRAM_CHAT_ID=""

# -------------------------------------------
# TRADING SETTINGS (Opsional - bisa di config.json)
# -------------------------------------------
TRADING_PAIR="BTC_IDR"
STRATEGY="TA"
TIMEFRAME="1h"
INITIAL_BALANCE=10000000
MAX_RISK_PER_TRADE=0.02
MAX_DRAWDOWN=0.05

# -------------------------------------------
# DATABASE & CACHE SETTINGS
# -------------------------------------------
DATABASE_URL="sqlite:///storage/trades.db"
REDIS_URL="redis://localhost:6379/0"

# -------------------------------------------
# LOGGING SETTINGS
# -------------------------------------------
LOG_LEVEL="INFO"
LOG_FILE="logs/bot.log"

# -------------------------------------------
# ENCRYPTION KEY (Jangan bagikan!)
# -------------------------------------------
# Digunakan untuk encrypt/decrypt API keys
# ENCRYPTION_KEY=""
